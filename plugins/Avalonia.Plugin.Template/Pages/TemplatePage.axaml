<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Avalonia.Plugin.Template.ViewModels"
             x:Class="Avalonia.Plugin.Template.Pages.TemplatePage"
             x:DataType="vm:TemplatePageViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450">
    <Grid Margin="16" RowDefinitions="Auto,*">
        
        <StackPanel Grid.Row="0" Spacing="4" Margin="0 0 0 24">
            <TextBlock Text="Template Plugin Demo" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="A minimal plugin example demonstrating the plugin system" FontSize="14" Opacity="0.6"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="24" HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="12" Padding="32" MinWidth="400">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    
                    <TextBlock Text="{Binding WelcomeMessage}" FontSize="20" FontWeight="SemiBold" 
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    
                    <TextBlock FontSize="14" Opacity="0.5" HorizontalAlignment="Center">
                        <Run Text="Click count: "/><Run Text="{Binding ClickCount}"/>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button Content="Click Me!" Command="{Binding IncrementCountCommand}" 
                                Classes="Primary" MinWidth="120"/>
                        <Button Content="Reset" Command="{Binding ResetCountCommand}" 
                                MinWidth="80"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Plugin Info" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock FontSize="12" Opacity="0.5">
                        This page is provided by the Template Plugin and loaded dynamically at runtime.
                        The plugin demonstrates ViewModel-View binding, commands, and menu integration.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
