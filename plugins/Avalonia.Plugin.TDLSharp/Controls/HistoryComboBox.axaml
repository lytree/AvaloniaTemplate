<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Avalonia.Plugin.TDLSharp.Controls.HistoryComboBox"
             x:CompileBindings="False"
             x:Name="Root">
    <Panel>
        <TextBox x:Name="InputBox"
                 Text="{Binding #Root.Text, Mode=TwoWay}"
                 PlaceholderText="{Binding #Root.PlaceholderText}"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Center" />
        <Button x:Name="ToggleDropdown"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Width="24"
                Margin="0,0,2,0"
                Focusable="False">
            <PathIcon Data="M7,10 L12,15 L17,10"
                      Width="12"
                      Height="12" />
        </Button>
        <Popup x:Name="HistoryPopup"
               IsLightDismissEnabled="True"
               PlacementTarget="{Binding #Root}"
               Placement="BottomEdgeAlignedLeft">
            <Border MinWidth="{Binding Bounds.Width, ElementName=Root}"
                    Background="{DynamicResource ComboBoxPopupBackground}"
                    BorderBrush="{DynamicResource ComboBoxPopupBorderBrush}"
                    BorderThickness="{DynamicResource ComboBoxPopupBorderThickness}"
                    BoxShadow="{DynamicResource ComboBoxPopupBoxShadow}"
                    CornerRadius="4"
                    Padding="4"
                    MaxHeight="250">
                <StackPanel Spacing="2">
                    <StackPanel.Styles>
                        <Style Selector="ListBoxItem:pointerover">
                            <Setter Property="Background" Value="{DynamicResource ComboBoxItemPointeroverBackground}" />
                        </Style>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="8 4" />
                            <Setter Property="CornerRadius" Value="4" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </StackPanel.Styles>
                    <ListBox x:Name="HistoryList"
                             SelectionMode="Single"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             MaxHeight="220" />
                    <Button x:Name="ClearAllButton"
                            Content="清除历史"
                            FontSize="12"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="8 4"
                            Background="Transparent"
                            BorderThickness="0" />
                </StackPanel>
            </Border>
        </Popup>
    </Panel>
</UserControl>
