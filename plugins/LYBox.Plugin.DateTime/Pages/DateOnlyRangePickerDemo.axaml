<UserControl
    x:Class="LYBox.Plugin.DateTimeControls.Pages.DateOnlyRangePickerDemo"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:viewModels="clr-namespace:LYBox.Plugin.DateTimeControls.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="viewModels:DateOnlyRangePickerDemoViewModel"
    mc:Ignorable="d">
    <StackPanel Margin="20" Spacing="20">
        <StackPanel HorizontalAlignment="Left">
            <TextBox
                Name="format"
                Text="yyyy-MM-dd"
                PlaceholderText="Display Format" />
            <TextBlock Text="Default" />
            <u:DateOnlyRangePicker
                Width="360"
                DisplayFormat="{Binding #format.Text}"
                SelectedEndDate="{Binding EndDate}"
                SelectedStartDate="{Binding StartDate}" />
            <TextBlock Text="Clear Button" />
            <u:DateOnlyRangePicker
                Width="360"
                Classes="ClearButton"
                DisplayFormat="{Binding #format.Text}" />
            <TextBlock Text="Initialized with Binding" />
            <u:DateOnlyRangePicker
                Width="360"
                DisplayFormat="{Binding #format.Text}"
                SelectedEndDate="{Binding EndDate}"
                SelectedStartDate="{Binding StartDate}" />
            <u:DateOnlyRangePicker
                Width="360"
                Classes="ClearButton"
                DisplayFormat="{Binding #format.Text}"
                SelectedEndDate="{Binding EndDate}"
                SelectedStartDate="{Binding StartDate}" />
            <TextBlock Text="IsReadOnly" />
            <ToggleSwitch Name="readonlyToggle" Content="Read Only" />
            <u:DateOnlyRangePicker
                Width="360"
                DisplayFormat="{Binding #format.Text}"
                IsReadOnly="{Binding #readonlyToggle.IsChecked}"
                SelectedEndDate="2025-06-30"
                SelectedStartDate="2025-06-26" />
        </StackPanel>
    </StackPanel>
</UserControl>
