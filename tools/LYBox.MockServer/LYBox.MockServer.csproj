<Project Sdk="Microsoft.NET.Sdk">
    <!-- LYBox.MockServer - dotnet tool，前端 Mock 后端 -->
    <!-- HostVersion 由 SDK 自动从仓库根 Directory.Build.props 链式继承，无需显式 Import -->

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <LangVersion>latest</LangVersion>

        <!-- 版本跟随仓库 HostVersion 真相源（由根 Directory.Build.props 提供）-->
        <Version>$(HostVersion)</Version>
        <AssemblyVersion>$(HostVersion)</AssemblyVersion>
        <FileVersion>$(HostVersion)</FileVersion>

        <!-- NuGet 包元数据 -->
        <PackageId>LYBox.MockServer</PackageId>
        <Title>LYBox Mock Server</Title>
        <Description>LYBox WebView 前端调试 Mock 后端。提供静态资源服务、Mock RPC、Mock SSE 推送，无需启动 Avalonia 即可调试前端。</Description>
        <Authors>LYBox</Authors>
        <PackageTags>lybox;avalonia;webview;mock;debug;tool</PackageTags>
        <PackageProjectUrl>https://github.com/AvaloniaTemplate/LYBox</PackageProjectUrl>
        <Copyright>Copyright (c) LYBox</Copyright>

        <!-- dotnet tool 配置 -->
        <PackAsTool>true</PackAsTool>
        <PackageType>DotnetTool</PackageType>
        <ToolCommandName>lybox-mock</ToolCommandName>
        <PackageOutputPath>$(MSBuildThisFileDirectory)../../bin/tools</PackageOutputPath>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>
</Project>
