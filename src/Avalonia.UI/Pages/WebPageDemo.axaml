<UserControl
    x:Class="Avalonia.UI.Pages.WebPageDemo"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Avalonia.UI.ViewModels"
    x:CompileBindings="True"
    x:DataType="vm:WebPageDemoViewModel"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">

    <Design.DataContext>
        <vm:WebPageDemoViewModel />
    </Design.DataContext>
   <TabControl x:Name="TabControl">
        <TabItem Header="AvaloniaUI">
            <Grid x:Name="GridContainer" RowDefinitions="Auto, 3*, *">
                <NativeWebView Grid.Row="1" x:Name="WebView"
                               Source="https://baidu.com/"
                               />
                <TextBox IsReadOnly="True" Grid.Row="2" x:Name="LogList" />
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
