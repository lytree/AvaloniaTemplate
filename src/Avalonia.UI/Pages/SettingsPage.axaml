<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Avalonia.UI.ViewModels"
             x:Class="Avalonia.UI.Pages.SettingsPage"
             x:DataType="viewModels:SettingsPageViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="16">
            <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource FluentTextPrimaryBrush}" />

            <Border Classes="FluentCard">
                <StackPanel Spacing="12">
                    <TextBlock Text="Theme" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource FluentTextPrimaryBrush}" />
                    <TextBlock Text="Select a theme for the application" FontSize="14"
                               Foreground="{DynamicResource FluentTextSecondaryBrush}" />
                    <ComboBox Width="200" ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" DisplayMemberBinding="{Binding Name}"/>
                </StackPanel>
            </Border>

            <Border Classes="FluentCard">
                <StackPanel Spacing="12">
                    <TextBlock Text="Interface" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource FluentTextPrimaryBrush}" />
                    <TextBlock Text="Customize the interface appearance" FontSize="14"
                               Foreground="{DynamicResource FluentTextSecondaryBrush}" />
                    <CheckBox IsChecked="{Binding IsCollapsed}" Content="Collapse Sidebar"/>
                </StackPanel>
            </Border>

            <Border Classes="FluentCard">
                <StackPanel Spacing="12">
                    <TextBlock Text="About" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource FluentTextPrimaryBrush}" />
                    <TextBlock Text="Avalonia UI Template" FontSize="16" FontWeight="Medium"
                               Foreground="{DynamicResource FluentTextPrimaryBrush}" />
                    <TextBlock Text="Version 1.0.0" FontSize="14"
                               Foreground="{DynamicResource FluentTextSecondaryBrush}" />
                    <TextBlock Text="A modern UI template built with Avalonia and Ursa controls." FontSize="14"
                               Foreground="{DynamicResource FluentTextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
