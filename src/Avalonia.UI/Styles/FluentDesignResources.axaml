    <StreamGeometry x:Key="SemiIconHome">M8 1L1 7V15H6V10H10V15H15V7L8 1Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconCamera">M9 2L7.17 4H2V14H14V4H10.83L9 2ZM9 7A2 2 0 1 1 9 11A2 2 0 0 1 9 7Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconStar">M8 1L10.17 5.44L15 6.12L11.5 9.53L12.34 14.34L8 12.06L3.66 14.34L4.5 9.53L1 6.12L5.83 5.44L8 1Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconLikeHeart">M8 14.5C8 14.5 1 10.25 1 5.5C1 3.01 3.01 1 5.5 1C6.87 1 8.09 1.62 8 2.5C8.09 1.62 9.13 1 10.5 1C12.99 1 15 3.01 15 5.5C15 10.25 8 14.5 8 14.5Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconBold">M4 2H9.5C11.16 2 12.5 3.34 12.5 5C12.5 6.66 11.16 8 9.5 8H4V2ZM4 8H10C11.66 8 13 9.34 13 11C13 12.66 11.66 14 10 14H4V8Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconItalic">M6 2H13L12 4H9.5L7 12H9.5L9 14H2L2.5 12H5L7.5 4H5L6 2Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconDownload">M7 10V15H9V10H13L8 4L3 10H7ZM2 16H14V18H2V16Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconArrowUp">M7 14L8 6L9 14H7ZM8 4L12 10H4L8 4Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconHelpCircle">M8 1C4.13 1 1 4.13 1 8C1 11.87 4.13 15 8 15C11.87 15 15 11.87 15 8C15 4.13 11.87 1 8 1ZM8.5 12H7.5V11H8.5V12ZM9.5 7.25C9.5 7.94 8.94 8.5 8.25 8.5H7.75V10H8.25C9.77 10 11 8.77 11 7.25V6.75C11 5.23 9.77 4 8.25 4H7.75C6.23 4 5 5.23 5 6.75V7H6.5V6.75C6.5 6.06 7.06 5.5 7.75 5.5H8.25C8.94 5.5 9.5 6.06 9.5 6.75V7.25Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconLock">M8 1C6.34 1 5 2.34 5 4V6H4V14H12V6H11V4C11 2.34 9.66 1 8 1ZM9 6H7V4C7 3.45 7.45 3 8 3C8.55 3 9 3.45 9 4V6Z</StreamGeometry>
    <StreamGeometry x:Key="SemiIconAIFilled">M12 2L14 8L20 10L14 12L12 18L10 12L4 10L10 8L12 2ZM5 15L6 18L5 21L4 18L1 17L4 16L5 13L6 16L5 15Z</StreamGeometry>

    <SolidColorBrush x:Key="SemiColorFill0" Color="{DynamicResource FluentCardBackgroundColor}" />
    <SolidColorBrush x:Key="SemiColorBackground1" Color="{DynamicResource FluentBackgroundColor}" />

</ResourceDictionary>
