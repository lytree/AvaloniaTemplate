<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="FluentAccentColor">#FF0078D4</Color>
            <Color x:Key="FluentAccentColor2">#FF106EBE</Color>
            <Color x:Key="FluentAccentColor3">#FF005A9E</Color>
            <Color x:Key="FluentBackgroundColor">#FFF3F3F3</Color>
            <Color x:Key="FluentCardBackgroundColor">#FFFFFFFF</Color>
            <Color x:Key="FluentCardBorderColor">#FFE5E5E5</Color>
            <Color x:Key="FluentTextPrimaryColor">#FF1A1A1A</Color>
            <Color x:Key="FluentTextSecondaryColor">#FF616161</Color>
            <Color x:Key="FluentTextTertiaryColor">#FF9E9E9E</Color>
            <Color x:Key="FluentDividerColor">#FFE0E0E0</Color>
            <Color x:Key="FluentHoverBackgroundColor">#FFE8E8E8</Color>
            <Color x:Key="FluentPressedBackgroundColor">#FFD4D4D4</Color>
            <Color x:Key="FluentSuccessColor">#FF0F7B0F</Color>
            <Color x:Key="FluentWarningColor">#FF9D5D00</Color>
            <Color x:Key="FluentDangerColor">#FFC42B1C</Color>
            <Color x:Key="FluentInfoColor">#FF0078D4</Color>
            <Color x:Key="FluentTagBlueColor">#FF0078D4</Color>
            <Color x:Key="FluentTagPurpleColor">#FF8764B8</Color>
            <Color x:Key="FluentTagGreenColor">#FF0F7B0F</Color>
            <Color x:Key="FluentTagRedColor">#FFC42B1C</Color>
            <Color x:Key="FluentTagOrangeColor">#FF9D5D00</Color>

            <SolidColorBrush x:Key="FluentAccentBrush" Color="{DynamicResource FluentAccentColor}" />
            <SolidColorBrush x:Key="FluentAccentBrush2" Color="{DynamicResource FluentAccentColor2}" />
            <SolidColorBrush x:Key="FluentAccentBrush3" Color="{DynamicResource FluentAccentColor3}" />
            <SolidColorBrush x:Key="FluentBackgroundBrush" Color="{DynamicResource FluentBackgroundColor}" />
            <SolidColorBrush x:Key="FluentCardBackgroundBrush" Color="{DynamicResource FluentCardBackgroundColor}" />
            <SolidColorBrush x:Key="FluentCardBorderBrush" Color="{DynamicResource FluentCardBorderColor}" />
            <SolidColorBrush x:Key="FluentTextPrimaryBrush" Color="{DynamicResource FluentTextPrimaryColor}" />
            <SolidColorBrush x:Key="FluentTextSecondaryBrush" Color="{DynamicResource FluentTextSecondaryColor}" />
            <SolidColorBrush x:Key="FluentTextTertiaryBrush" Color="{DynamicResource FluentTextTertiaryColor}" />
            <SolidColorBrush x:Key="FluentDividerBrush" Color="{DynamicResource FluentDividerColor}" />
            <SolidColorBrush x:Key="FluentHoverBackgroundBrush" Color="{DynamicResource FluentHoverBackgroundColor}" />
            <SolidColorBrush x:Key="FluentPressedBackgroundBrush" Color="{DynamicResource FluentPressedBackgroundColor}" />
            <SolidColorBrush x:Key="FluentSuccessBrush" Color="{DynamicResource FluentSuccessColor}" />
            <SolidColorBrush x:Key="FluentWarningBrush" Color="{DynamicResource FluentWarningColor}" />
            <SolidColorBrush x:Key="FluentDangerBrush" Color="{DynamicResource FluentDangerColor}" />
            <SolidColorBrush x:Key="FluentInfoBrush" Color="{DynamicResource FluentInfoColor}" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <Color x:Key="FluentAccentColor">#FF60CDFF</Color>
            <Color x:Key="FluentAccentColor2">#FF4CC2FF</Color>
            <Color x:Key="FluentAccentColor3">#FF38B8FF</Color>
            <Color x:Key="FluentBackgroundColor">#FF202020</Color>
            <Color x:Key="FluentCardBackgroundColor">#FF2D2D2D</Color>
            <Color x:Key="FluentCardBorderColor">#FF3D3D3D</Color>
            <Color x:Key="FluentTextPrimaryColor">#FFFFFFFF</Color>
            <Color x:Key="FluentTextSecondaryColor">#FFB0B0B0</Color>
            <Color x:Key="FluentTextTertiaryColor">#FF787878</Color>
            <Color x:Key="FluentDividerColor">#FF3D3D3D</Color>
            <Color x:Key="FluentHoverBackgroundColor">#FF3D3D3D</Color>
            <Color x:Key="FluentPressedBackgroundColor">#FF4D4D4D</Color>
            <Color x:Key="FluentSuccessColor">#FF6CCB5F</Color>
            <Color x:Key="FluentWarningColor">#FFFCE100</Color>
            <Color x:Key="FluentDangerColor">#FFFF6B6B</Color>
            <Color x:Key="FluentInfoColor">#FF60CDFF</Color>
            <Color x:Key="FluentTagBlueColor">#FF60CDFF</Color>
            <Color x:Key="FluentTagPurpleColor">#FFB4A0D1</Color>
            <Color x:Key="FluentTagGreenColor">#FF6CCB5F</Color>
            <Color x:Key="FluentTagRedColor">#FFFF6B6B</Color>
            <Color x:Key="FluentTagOrangeColor">#FFFCE100</Color>

            <SolidColorBrush x:Key="FluentAccentBrush" Color="{DynamicResource FluentAccentColor}" />
            <SolidColorBrush x:Key="FluentAccentBrush2" Color="{DynamicResource FluentAccentColor2}" />
            <SolidColorBrush x:Key="FluentAccentBrush3" Color="{DynamicResource FluentAccentColor3}" />
            <SolidColorBrush x:Key="FluentBackgroundBrush" Color="{DynamicResource FluentBackgroundColor}" />
            <SolidColorBrush x:Key="FluentCardBackgroundBrush" Color="{DynamicResource FluentCardBackgroundColor}" />
            <SolidColorBrush x:Key="FluentCardBorderBrush" Color="{DynamicResource FluentCardBorderColor}" />
            <SolidColorBrush x:Key="FluentTextPrimaryBrush" Color="{DynamicResource FluentTextPrimaryColor}" />
            <SolidColorBrush x:Key="FluentTextSecondaryBrush" Color="{DynamicResource FluentTextSecondaryColor}" />
            <SolidColorBrush x:Key="FluentTextTertiaryBrush" Color="{DynamicResource FluentTextTertiaryColor}" />
            <SolidColorBrush x:Key="FluentDividerBrush" Color="{DynamicResource FluentDividerColor}" />
            <SolidColorBrush x:Key="FluentHoverBackgroundBrush" Color="{DynamicResource FluentHoverBackgroundColor}" />
            <SolidColorBrush x:Key="FluentPressedBackgroundBrush" Color="{DynamicResource FluentPressedBackgroundColor}" />
            <SolidColorBrush x:Key="FluentSuccessBrush" Color="{DynamicResource FluentSuccessColor}" />
            <SolidColorBrush x:Key="FluentWarningBrush" Color="{DynamicResource FluentWarningColor}" />
            <SolidColorBrush x:Key="FluentDangerBrush" Color="{DynamicResource FluentDangerColor}" />
            <SolidColorBrush x:Key="FluentInfoBrush" Color="{DynamicResource FluentInfoColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <CornerRadius x:Key="FluentCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="FluentCardCornerRadius">8</CornerRadius>
    <x:Double x:Key="FluentCardPadding">16</x:Double>
    <x:Double x:Key="FluentCardMargin">8</x:Double>
    <x:Double x:Key="FluentSectionSpacing">12</x:Double>
    <x:Double x:Key="FluentContentMargin">16</x:Double>
    <x:Double x:Key="SemiSpacingExtraTight">4</x:Double>

    <Thickness x:Key="FluentCardBorderThickness">1</Thickness>
    <Thickness x:Key="FluentCardPaddingThickness">16</Thickness>
    <Thickness x:Key="FluentContentPadding">16</Thickness>

    <ControlTheme x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource FluentCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluentCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BoxShadow" Value="0 1 4 0 #0A000000" />
    </ControlTheme>

    <ControlTheme x:Key="TitleTextBlock" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimaryBrush}" />
    </ControlTheme>

    <ControlTheme x:Key="BorderlessIconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}">
                    <ContentPresenter
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource FluentHoverBackgroundBrush}" />
        </Style>
        <Style Selector="^:pressed">
            <Setter Property="Background" Value="{DynamicResource FluentPressedBackgroundBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="TagLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimaryBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}">
                    <ContentPresenter
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^.Blue">
            <Setter Property="Background" Value="#1A0078D4" />
            <Setter Property="Foreground" Value="{DynamicResource FluentAccentBrush}" />
        </Style>
        <Style Selector="^.Purple">
            <Setter Property="Background" Value="#1A8764B8" />
            <Setter Property="Foreground" Value="{DynamicResource FluentTagPurpleBrush}" />
        </Style>
        <Style Selector="^.Green">
            <Setter Property="Background" Value="#1A0F7B0F" />
            <Setter Property="Foreground" Value="{DynamicResource FluentSuccessBrush}" />
        </Style>
        <Style Selector="^.Red">
            <Setter Property="Background" Value="#1AC42B1C" />
            <Setter Property="Foreground" Value="{DynamicResource FluentDangerBrush}" />
        </Style>
        <Style Selector="^.Orange">
            <Setter Property="Background" Value="#1A9D5D00" />
            <Setter Property="Foreground" Value="{DynamicResource FluentWarningBrush}" />
        </Style>
        <Style Selector="^.Ghost">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource FluentCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="^.Blue.Ghost">
            <Setter Property="Foreground" Value="{DynamicResource FluentAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FluentAccentBrush}" />
        </Style>
        <Style Selector="^.Purple.Ghost">
            <Setter Property="Foreground" Value="{DynamicResource FluentTagPurpleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FluentTagPurpleBrush}" />
        </Style>
    </ControlTheme>

    <SolidColorBrush x:Key="FluentTagPurpleBrush" Color="{DynamicResource FluentTagPurpleColor}" />

    <StreamGeometry x:Key="SemiIconSetting">M12 0C10.9 0 10 0.9 10 2C10 3.1 10.9 4 12 4C13.1 4 14 3.1 14 2C14 0.9 13.1 0 12 0ZM12 6C10.9 6 10 6.9 10 8C10 9.1 10.9 10 12 10C13.1 10 14 9.1 14 8C14 6.9 13.1 6 12 6ZM12 12C10.9 12 10 12.9 10 14C10 15.1 10.9 16 12 16C13.1 16 14 15.1 14 14C14 12.9 13.1 12 12 12Z</StreamGeometry>
