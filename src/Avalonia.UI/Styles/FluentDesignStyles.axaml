<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:u="https://irihi.tech/ursa">

    <Style Selector="Border.FluentCard">
        <Setter Property="Background" Value="{DynamicResource FluentCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluentCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource FluentCardBorderThickness}" />
        <Setter Property="CornerRadius" Value="{DynamicResource FluentCardCornerRadius}" />
        <Setter Property="Padding" Value="{DynamicResource FluentCardPaddingThickness}" />
        <Setter Property="Margin" Value="{DynamicResource FluentCardMargin}" />
        <Setter Property="BoxShadow" Value="0 2 8 0 #18000000" />
    </Style>

    <Style Selector="Border.FluentCard:pointerover">
        <Setter Property="BoxShadow" Value="0 4 16 0 #22000000" />
    </Style>

    <Style Selector="TextBlock.FluentSectionTitle">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="TextBlock.FluentPageTitle">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.FluentSectionHeader">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.FluentBody">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource FluentTextSecondaryBrush}" />
    </Style>

    <Style Selector="TextBlock.FluentCaption">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource FluentTextTertiaryBrush}" />
    </Style>

    <Style Selector="Button.FluentAccent">
        <Setter Property="Background" Value="{DynamicResource FluentAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.FluentAccent:pointerover">
        <Setter Property="Background" Value="{DynamicResource FluentAccentBrush2}" />
    </Style>

    <Style Selector="Button.FluentAccent:pressed">
        <Setter Property="Background" Value="{DynamicResource FluentAccentBrush3}" />
    </Style>

    <Style Selector="Border.SectionCard">
        <Setter Property="Background" Value="{DynamicResource FluentCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluentCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource FluentCardCornerRadius}" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="BoxShadow" Value="0 1 4 0 #0A000000" />
    </Style>

    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimaryBrush}" />
    </Style>

    <Style Selector="u|NavMenu">
        <Setter Property="Background" Value="{DynamicResource FluentCardBackgroundBrush}" />
    </Style>

    <Style Selector="u|Banner">
        <Setter Property="CornerRadius" Value="{DynamicResource FluentCornerRadius}" />
    </Style>

    <Style Selector="u|Badge">
        <Setter Property="Margin" Value="4" />
    </Style>

    <Style Selector="u|DualBadge">
        <Setter Property="Margin" Value="3" />
    </Style>

    <Style Selector="u|RangeSlider">
        <Setter Property="Foreground" Value="{DynamicResource FluentAccentBrush}" />
    </Style>

    <Style Selector="u|Toast /template/ Border#RootBorder">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BoxShadow" Value="0 4 12 0 #33000000" />
    </Style>

    <Style Selector="u|NumericUpDown">
        <Setter Property="Foreground" Value="{DynamicResource FluentTextPrimaryBrush}" />
    </Style>

    <Style Selector="u|StandardDialogWindow">
        <Setter Property="Background" Value="{DynamicResource FluentCardBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="u|MessageBoxWindow">
        <Setter Property="Background" Value="{DynamicResource FluentCardBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

</Styles>
