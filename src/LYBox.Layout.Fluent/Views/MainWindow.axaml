<view:FluentWindow
  x:Class="LYBox.Layout.Fluent.Views.MainWindow"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ani="clr-namespace:AvaloniaFluentUI.Media.Animation;assembly=LYBox.Layout.Fluent"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:fi="clr-namespace:AvaloniaFluentUI.Icons;assembly=LYBox.Layout.Fluent"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=LYBox.Layout.Fluent"
  xmlns:locale="clr-namespace:AvaloniaFluentUI.Locale;assembly=LYBox.Layout.Fluent"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="clr-namespace:LYBox.Layout.Fluent.Controls"
  xmlns:view="clr-namespace:AvaloniaFluentUI.Windowing;assembly=LYBox.Layout.Fluent"
  xmlns:vm="using:LYBox.Layout.Fluent.ViewModels"
  xmlns:pluginVm="using:LYBox.Plugin.Shared.ViewModels"
  Title="{Binding Title}"
  Width="1200"
  Height="800"
  MinWidth="750"
  MinHeight="500"
  d:DesignHeight="1080"
  d:DesignWidth="1920"
  x:DataType="vm:MainWindowViewModel"
  Icon="/Assets/app.ico"
  IconSize="20"
  TitleBarMargin="40 0 0 0"
  WindowStartupLocation="CenterScreen"
  mc:Ignorable="d">
  <!--  BorderBrush="{Binding BorderBrush}"  -->
  <!--  BorderThickness="{Binding BorderWidth}"  -->

  <Design.DataContext>
    <!--
      This only sets the DataContext for the previewer in an IDE,
      to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs)
    -->
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Window.Styles>
    <Style Selector="UserControl">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="Window">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="fui|NavigationViewItem.Icon /template/ Viewbox#IconBox ContentPresenter#Icon fui|FluentPathIcon">
      <Setter Property="Margin" Value="3"/>
    </Style>

    <Style Selector="view|AppSplashScreen">
      <Setter Property="Background" Value="#FFFFFF"/>
    </Style>
  </Window.Styles>


  <view:FluentWindow.TitleBarContent>
    <Grid ColumnDefinitions="*, Auto, Auto, Auto">
      <fui:SearchTextBox
        Width="256"
        Margin="0,10,0,0"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        PlaceholderText="{Binding SearchWatermark}"/>

      <fui:ToolButton
        Name="SettingButton"
        Grid.Column="1"
        Width="46"
        Height="45"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Classes="Transparent"
        Content="{x:Static fi:FluentIcon.Setting}">
        <fui:ToolButton.Flyout>
          <fui:FluentFlyout Placement="Bottom">
            <Grid
              MaxWidth="288"
              MaxHeight="328"
              Margin="15"
              ColumnDefinitions="Auto, *"
              ColumnSpacing="6"
              RowDefinitions="Auto, Auto"
              RowSpacing="8">
              <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="边框宽度"/>
              <ComboBox
                Grid.Row="0"
                Grid.Column="1"
                MinWidth="100"
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding BorderWidthItems}"
                SelectedItem="{Binding SelectedBorderWidthItem}"/>

              <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="边框颜色"/>
              <fui:ColorPickerButton
                Grid.Row="1"
                Grid.Column="1"
                Click="OnHideFlyout"
                Color="{Binding SelectedBorderColor}"/>
            </Grid>
          </fui:FluentFlyout>
        </fui:ToolButton.Flyout>
      </fui:ToolButton>

      <fui:ToolButton
        Name="PinButton"
        Grid.Column="2"
        Width="46"
        Height="45"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Classes="Transparent"
        Click="OnToggleTopmost"
        Content="{x:Static fi:FluentIcon.Pin}"
        Tag="noTopmost"/>
      <fui:ToolButton
        Grid.Column="3"
        Width="46"
        Height="45"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Classes="Transparent"
        Command="{Binding ToggleThemeCommand}"
        Content="M15 3v-2q0-0.406 0.297-0.703t0.703-0.297 0.703 0.297 0.297 0.703v2q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297-0.297-0.703zM8 7q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297l-2-2q-0.297-0.297-0.297-0.703t0.297-0.703 0.703-0.297 0.703 0.297l2 2q0.297 0.297 0.297 0.703zM27 4q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703l-2 2q-0.297 0.297-0.703 0.297t-0.703-0.297-0.297-0.703 0.297-0.703l2-2q0.297-0.297 0.703-0.297zM24 16v0.156q0 1.625-0.648 3.055t-1.75 2.492-2.547 1.68-3.055 0.617q-1.656 0-3.117-0.625t-2.547-1.711-1.711-2.547-0.625-3.117 0.625-3.117 1.711-2.547 2.547-1.711 3.117-0.625 3.117 0.625 2.547 1.711 1.711 2.547 0.625 3.117zM16 22h0.125q1.219 0 2.289-0.484t1.867-1.313 1.258-1.914 0.461-2.289-0.461-2.289-1.258-1.914-1.867-1.313-2.289-0.484h-0.125v12zM3 15q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703-0.703 0.297h-2q-0.406 0-0.703-0.297t-0.297-0.703 0.297-0.703 0.703-0.297h2zM31 15q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703-0.703 0.297h-2q-0.406 0-0.703-0.297t-0.297-0.703 0.297-0.703 0.703-0.297h2zM7 24q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703l-2 2q-0.297 0.297-0.703 0.297t-0.703-0.297-0.297-0.703 0.297-0.703l2-2q0.297-0.297 0.703-0.297zM28 27q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297l-2-2q-0.297-0.297-0.297-0.703t0.297-0.703 0.703-0.297 0.703 0.297l2 2q0.297 0.297 0.297 0.703zM17 29v2q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297-0.297-0.703v-2q0-0.406 0.297-0.703t0.703-0.297 0.703 0.297 0.297 0.703z"
        ToolTip.Tip="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[ToggleTheme]}"/>
    </Grid>
  </view:FluentWindow.TitleBarContent>

  <Grid Margin="0,0,0,0">

    <Image
      x:Name="BackgroundImage"
      Grid.RowSpan="2"
      Grid.ColumnSpan="2"
      IsHitTestVisible="False"
      IsVisible="False"
      Opacity="0.3"
      Stretch="UniformToFill"/>

    <fui:NavigationView
      Name="NavigationView"
      Grid.Column="0"
      AlwaysShowHeader="False"
      BackCommand="{Binding GoBackCommand}"
      Background="Transparent"
      IsBackButtonVisible="True"
      IsBackEnabled="True"
      IsSettingsVisible="True"
      PaneDisplayMode="Auto"
      PaneFooterSeparatorIsVisible="True"
      SelectedItem="{Binding NavigationViewSelectedItem, Mode=TwoWay}">

      <fui:NavigationView.AutoCompleteBox>
        <fui:SearchTextBox PlaceholderText="{Binding SearchWatermark}"/>
      </fui:NavigationView.AutoCompleteBox>

      <fui:NavigationView.PaneFooter>
        <Panel
          Height="35"
          Background="#01000000"
          PointerReleased="OnPopupContextMenu">
          <fui:Avatar
            Name="Avatar"
            Width="28"
            Height="28"
            Margin="12,0,0,0"
            HorizontalAlignment="Left"
            CornerRadius="14"
            PointerReleased="OnPopupAvatarFlyout"
            Source="avares://LYBox.Layout.Fluent/Assets/Images/na.jpg"/>
          <TextBlock
            Margin="50,0,0,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Classes="Body"
            IsVisible="{Binding #NavigationView.IsPaneOpen}"
            Text="Izumi"/>

          <Panel.ContextMenu>
            <fui:FluentContextMenu MinWidth="300">
              <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto">
                <fui:Avatar
                  Grid.RowSpan="3"
                  Grid.Column="0"
                  Width="64"
                  Height="64"
                  Margin="-18,0,10,0"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  CornerRadius="32"
                  Source="avares://LYBox.Layout.Fluent/Assets/Images/na.jpg"/>
                <TextBlock
                  Grid.Row="0"
                  Grid.Column="1"
                  Margin="11,0,0,0"
                  VerticalAlignment="Center"
                  FontSize="18"
                  Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_LoginName]}"/>
                <TextBlock
                  Grid.Row="1"
                  Grid.Column="1"
                  Margin="11,0,0,0"
                  VerticalAlignment="Center"
                  FontSize="12"
                  Text="hanserinterval@outlook.com"/>
                <Button
                  Grid.Row="2"
                  Grid.Column="1"
                  HorizontalAlignment="Left"
                  Classes="Transparent"
                  Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Logout]}"
                  Foreground="{DynamicResource SystemAccentColor}"/>
              </Grid>
              <Separator HorizontalAlignment="Stretch"/>
              <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ManageAccounts]}">
                <MenuItem.Icon>
                  <PathIcon Data="{x:Static fi:FluentIcon.People}"/>
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_PaymentMethods]}">
                <MenuItem.Icon>
                  <PathIcon Data="{x:Static fi:FluentIcon.ShoppingCart}"/>
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RedeemCode]}">
                <MenuItem.Icon>
                  <PathIcon Data="{x:Static fi:FluentIcon.Code}"/>
                </MenuItem.Icon>
              </MenuItem>
              <Separator HorizontalAlignment="Stretch"/>
              <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Settings]}">
                <MenuItem.Icon>
                  <PathIcon Data="{x:Static fi:FluentIcon.Setting}"/>
                </MenuItem.Icon>
              </MenuItem>
            </fui:FluentContextMenu>
          </Panel.ContextMenu>
        </Panel>
      </fui:NavigationView.PaneFooter>

      <fui:NavigationView.MenuItemTemplate>
        <DataTemplate x:DataType="pluginVm:MenuItemViewModel">
          <fui:NavigationViewItem
            Content="{Binding MenuHeader}"
            Tag="{Binding Key}"
            SelectsOnInvoked="True"/>
        </DataTemplate>
      </fui:NavigationView.MenuItemTemplate>
      <fui:NavigationView.MenuItems>
        <fui:NavigationViewItem
          Content="{Binding Home}"
          IconSource="M5.322 32q-0.884 0-1.66-0.334t-1.36-0.918-0.918-1.36-0.334-1.66v-12.997q0-0.634 0.25-1.235t0.684-1.034l11.378-11.362q0.534-0.534 1.21-0.818t1.426-0.284 1.427 0.284 1.21 0.818l11.378 11.362q0.434 0.434 0.684 1.034t0.25 1.235v12.997q0 0.884-0.334 1.66t-0.918 1.36-1.36 0.918-1.66 0.334h-6.407q-0.45 0-0.843-0.167t-0.676-0.45-0.45-0.676-0.167-0.843v-8.542h-4.271v8.542q0 0.45-0.167 0.834t-0.459 0.676-0.676 0.459-0.834 0.167h-6.407zM11.729 29.864v-8.542q0-0.45 0.167-0.834t0.459-0.676 0.676-0.459 0.834-0.167h4.271q0.434 0 0.826 0.167t0.684 0.459 0.459 0.684 0.167 0.826v8.542h6.407q0.45 0 0.834-0.167t0.676-0.459 0.459-0.676 0.167-0.834v-12.997q0-0.434-0.317-0.751l-11.362-11.379q-0.467-0.467-1.135-0.467t-1.135 0.467l-11.362 11.379q-0.317 0.317-0.317 0.751v12.997q0 0.45 0.167 0.843t0.45 0.676 0.676 0.45 0.843 0.167h6.407z"
          IsSelected="True"
          Tag="Home"/>
        <fui:NavigationViewItem
          Content="工具箱"
          IconSource="M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z"
          Tag="Introduction"/>
        <fui:NavigationViewItem
          Content="插件管理"
          IconSource="M3 4h6v6H3V4zm8 0h6v6h-6V4zm8 0h6v6h-6V4zM3 12h6v6H3v-6zm8 0h6v6h-6v-6zm8 0h6v6h-6v-6zM3 20h6v6H3v-6zm8 0h6v6h-6v-6zm8 0h6v6h-6v-6z"
          Tag="PluginManagement"/>
        <!--  插件提供的菜单项（数据绑定，使用 MenuItemsSource 而非 ItemsSource）  -->
        <fui:NavigationViewItemSeparator IsVisible="{Binding PluginMenus.Count}"/>
        <fui:NavigationViewItem
          Content="插件"
          IconSource="M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z"
          IsExpanded="True"
          MenuItemsSource="{Binding PluginMenus}"
          SelectsOnInvoked="False"/>
      </fui:NavigationView.MenuItems>

      <fui:NavigationView.Content>
        <fui:StackContent Content="{Binding CurrentViewModel}"/>
      </fui:NavigationView.Content>
    </fui:NavigationView>
  </Grid>

</view:FluentWindow>
