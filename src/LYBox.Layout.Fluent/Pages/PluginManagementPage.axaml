<UserControl
    x:Class="LYBox.Layout.Fluent.Pages.PluginManagementPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:LYBox.Layout.Fluent.ViewModels;assembly=LYBox.Layout.Fluent"
    xmlns:coreVm="clr-namespace:LYBox.Layout.Core.ViewModels;assembly=LYBox.Layout.Core"
    x:CompileBindings="True"
    x:DataType="vm:PluginManagementViewModel"
    d:DesignWidth="900"
    d:DesignHeight="600"
    mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="Border.PluginCard">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.PageTitle">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.PageDesc">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="TextBlock.PluginName">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.Caption">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="Button.ActionBtn">
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Border.StateBadge">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="插件管理" Classes="PageTitle" />
            <TextBlock Text="安装、卸载、启用或禁用插件" Classes="PageDesc" />
        </StackPanel>

        <!-- Action Bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    Content="安装插件"
                    Classes="ActionBtn"
                    Command="{Binding InstallPluginCommand}"
                    IsEnabled="{Binding !IsInstalling}" />
                <Button
                    Content="刷新"
                    Classes="ActionBtn"
                    Command="{Binding RefreshPluginsCommand}" />
                <Button
                    Content="打开插件目录"
                    Classes="ActionBtn"
                    Command="{Binding OpenPluginDirectoryCommand}"
                    ToolTip.Tip="{Binding PluginsDirectory}" />
            </StackPanel>
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Classes="Caption"
                Text="{Binding StatusMessage}" />
        </Grid>

        <!-- Plugin Directory Path -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Classes="Caption" Text="插件目录:" />
            <TextBlock Classes="Caption" Text="{Binding PluginsDirectory}" TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <!-- Restart Warning -->
        <Border
            Grid.Row="2"
            IsVisible="{Binding NeedsRestart}"
            Background="{DynamicResource CautionColorSubtleBrush}"
            BorderBrush="{DynamicResource CautionColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="12,8"
            Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚠" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="需要重启应用以应用更改" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Install Progress -->
        <ProgressBar
            Grid.Row="1"
            IsVisible="{Binding IsInstalling}"
            Value="{Binding InstallProgress}"
            Height="4"
            Margin="0,40,0,0" />

        <!-- Plugin List -->
        <Grid Grid.Row="4">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Plugins}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="coreVm:PluginItemViewModel">
                            <Border Classes="PluginCard">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">

                                    <!-- Row 0: Name + State Badge -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Classes="PluginName" Text="{Binding Name}" />
                                        <Border Classes="StateBadge" Background="{Binding StateColor}">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="White"
                                                Text="{Binding StateText}" />
                                        </Border>
                                    </StackPanel>

                                    <!-- Row 0 Col 1: Action Buttons -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Button
                                            Classes="ActionBtn"
                                            Content="启用"
                                            Command="{Binding $parent[UserControl].DataContext.EnablePluginCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding CanEnable}" />
                                        <Button
                                            Classes="ActionBtn"
                                            Content="禁用"
                                            Command="{Binding $parent[UserControl].DataContext.DisablePluginCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding CanDisable}" />
                                        <Button
                                            Classes="ActionBtn"
                                            Content="卸载"
                                            Command="{Binding $parent[UserControl].DataContext.UninstallPluginCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding CanUninstall}" />
                                        <Button
                                            Classes="ActionBtn"
                                            Content="取消升级"
                                            Command="{Binding $parent[UserControl].DataContext.CancelUpgradeCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding CanCancelUpgrade}" />
                                    </StackPanel>

                                    <!-- Row 1: Version / Author -->
                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                        <TextBlock Classes="Caption">
                                            <Run Text="版本: " /><Run Text="{Binding Version}" />
                                        </TextBlock>
                                        <TextBlock
                                            Classes="Caption"
                                            IsVisible="{Binding PendingUpgradeVersion, Converter={x:Static ObjectConverters.IsNotNull}}">
                                            <Run Text="待升级版本: " /><Run Text="{Binding PendingUpgradeVersion}" />
                                        </TextBlock>
                                        <TextBlock Classes="Caption">
                                            <Run Text="作者: " /><Run Text="{Binding Author}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Row 2: Description -->
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Margin="0,4,0,0"
                                        Text="{Binding Description}"
                                        TextWrapping="Wrap"
                                        MaxHeight="40" />

                                    <!-- Row 3: Error Message -->
                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.ColumnSpan="2"
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                        IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                        Text="{Binding ErrorMessage}"
                                        TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty State -->
            <Border
                IsVisible="{Binding Plugins.Count, Converter={x:Static coreVm:PluginStateConverters.IsEmpty}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,40,0,0"
                Padding="32"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="16"
                        Text="尚未安装任何插件" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Classes="Caption"
                        Text="点击上方&quot;安装插件&quot;按钮选择插件包" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
