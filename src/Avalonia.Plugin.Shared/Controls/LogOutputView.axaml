<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="Avalonia.Plugin.Shared.Controls.LogOutputView"
			 x:CompileBindings="True">
	<Grid RowDefinitions="Auto,*">
		<Grid ColumnDefinitions="*,Auto" Margin="0 0 0 8">
			<TextBlock Grid.Column="0" Text="日志输出" Classes="SectionTitle" VerticalAlignment="Center" />
			<Button Grid.Column="1" Content="清除" FontSize="12" Padding="8 4" Click="OnClearLog" />
		</Grid>
		<ListBox x:Name="LogListBox" Grid.Row="1"
				 ItemsSource="{Binding LogEntries, RelativeSource={RelativeSource AncestorType=UserControl}}"
				 SelectionMode="Toggle"
				 ScrollViewer.VerticalScrollBarVisibility="Auto"
				 ScrollViewer.HorizontalScrollBarVisibility="Auto">
			<ListBox.Styles>
				<Style Selector="ListBoxItem">
					<Setter Property="Padding" Value="2 1" />
					<Setter Property="HorizontalContentAlignment" Value="Stretch" />
				</Style>
			</ListBox.Styles>
			<ListBox.ItemTemplate>
				<DataTemplate>
					<SelectableTextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap">
						<SelectableTextBlock.ContextMenu>
							<ContextMenu x:CompileBindings="False">
								<MenuItem Header="复制" Click="OnCopyLogEntry" />
							</ContextMenu>
						</SelectableTextBlock.ContextMenu>
					</SelectableTextBlock>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</UserControl>
