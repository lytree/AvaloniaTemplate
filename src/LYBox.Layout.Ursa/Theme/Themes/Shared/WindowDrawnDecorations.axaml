<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="WindowCloseIconGlyph" ResourceKey="FluentIconClose" />
    <StaticResource x:Key="WindowMinimizeGlyph" ResourceKey="FluentIconMinus" />
    <StaticResource x:Key="WindowExpandGlyph" ResourceKey="FluentIconExpand" />
    <StaticResource x:Key="WindowCollapseGlyph" ResourceKey="FluentIconShrink" />
    <StaticResource x:Key="WindowMaximizeGlyph" ResourceKey="FluentIconMaximize2" />
    <StaticResource x:Key="WindowRestoreGlyph" ResourceKey="FluentIconRestore" />

    <!-- WinUI 3 风格 caption buttons：无圆角、固定宽度、高度匹配标题栏 -->
    <CornerRadius x:Key="CaptionButtonCornerRadius">0</CornerRadius>
    <x:Double x:Key="CaptionButtonWidth">46</x:Double>
    <x:Double x:Key="CaptionButtonHeight">48</x:Double>
    <Thickness x:Key="CaptionButtonPadding">0</Thickness>
</ResourceDictionary>